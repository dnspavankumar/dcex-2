# ==========================================
# Exchange Infrastructure Environment Configuration
# ==========================================

# 1. Neon Database Persistence (PostgreSQL)
EXCHANGE_DATABASE_URL="jdbc:postgresql://ep-production-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require"
# EXCHANGE_DATABASE_USERNAME and EXCHANGE_DATABASE_PASSWORD are not needed 
# if your NeonDB URL already contains ?user=...&password=...
EXCHANGE_DATABASE_BATCH_THRESHOLD=1000
EXCHANGE_DATABASE_FLUSH_INTERVAL_MS=500

# 2. Write-Ahead Log (WAL) & Disaster Recovery
EXCHANGE_WAL_DIRECTORY="/data/wal/production"
EXCHANGE_WAL_MAPPED_SIZE_MB=256
EXCHANGE_WAL_FSYNC_ENABLED=true

# 3. Security & Access
EXCHANGE_SECURITY_JWT_SECRET="generate-a-secure-256-bit-key-for-hmac-sha-signing-here"

# 4. Networking & Protocols
EXCHANGE_NETWORK_GRPC_PORT=9090
EXCHANGE_NETWORK_WEBSOCKET_PORT=8080

# 5. JVM & Matching Engine Tuning
EXCHANGE_TUNING_RING_BUFFER_CAPACITY=16384
EXCHANGE_TUNING_SNAPSHOT_INTERVAL_SECONDS=10
EXCHANGE_TUNING_GC_PROFILE="ZGC"

# Infrastructure Level Settings (JVM Flags)
# MALLOC_ARENA_MAX=2
# NUMA_NODE=0
